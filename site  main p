                <h3 class="a3-section-title">5) Plano de Ação</h3>
                <textarea id="a3-plano" placeholder="Ex: 1. Trocar sensor (João - 10/05)..."></textarea>
                <input type="file" id="pdf-plano" accept=".pdf">
              </div>

