
<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="description" content="Grupo Vertex — empresas especializadas, soluções conectadas.">
  <title>Grupo Vertex | Soluções conectadas</title>
  <style>
    :root { 
      --ink: #15213b; --muted: #65708a; --surface: #fff; --line: #e6eaf2; 
      --blue: #315efb; --purple: #7c3aed; --pink: #e84d9b; --orange: #ff7a18; 
      --green: #12a879; --teal: #16b7ba; --shadow: 0 18px 55px rgba(38,55,101,.13); 
    }
    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body { 
      margin: 0; color: var(--ink); background: #f7f9ff; 
      font: 16px/1.55 Inter, ui-sans-serif, system-ui, -apple-system, sans-serif; 
    }
    button, input, select, textarea { font: inherit; }
    button, a { -webkit-tap-highlight-color: transparent; }
    
    .shell { width: min(1160px, calc(100% - 32px)); margin: auto; }
    .topbar { 
      position: sticky; top: 0; z-index: 10; 
      border-bottom: 1px solid rgba(255,255,255,.28); 
      backdrop-filter: blur(18px); background: rgba(247,249,255,.84); 
    }
    .nav { min-height: 72px; display: flex; align-items: center; justify-content: space-between; gap: 18px; }
    .brand { display: flex; align-items: center; gap: 10px; color: var(--ink); font-weight: 850; text-decoration: none; letter-spacing: .04em; }
    
    .brand-logo { 
      width: 45px; 
      height: 45px; 
      object-fit: contain; 
      mix-blend-mode: multiply;
    }

    .nav-links { display: flex; flex-wrap: wrap; gap: 6px; }
    .nav-links button { border: 0; border-radius: 999px; padding: 8px 11px; color: var(--muted); background: transparent; cursor: pointer; font-weight: 600; }
    .nav-links button:hover, .nav-links button.active { color: #fff; background: var(--ink); }
    
    .view { display: none; padding: 42px 0 72px; animation: fadeIn 0.4s ease; }
    .view.active { display: block; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

    /* Hero Section */
    .hero { 
      overflow: hidden; position: relative; padding: 58px; border-radius: 30px; 
      color: #fff; background: linear-gradient(122deg, #17264c 0%, #ff5e00 48%, #ffb300 100%); 
      box-shadow: var(--shadow); 
    }
    .hero::after { 
      position: absolute; content: ""; width: 420px; height: 420px; right: -150px; top: -205px; 
      border-radius: 50%; background: radial-gradient(circle, #ffcb72 0 12%, rgba(255,255,255,.18) 13% 31%, transparent 32%); transform: rotate(18deg); 
    }
    .hero-grid { position: relative; z-index: 1; display: grid; grid-template-columns: 1.18fr .82fr; gap: 32px; align-items: center; }
    .eyebrow { display: inline-flex; padding: 5px 10px; border-radius: 999px; background: rgba(255,255,255,.18); font-size: .78rem; font-weight: 750; letter-spacing: .08em; text-transform: uppercase; }
    h1, h2, h3, p { margin-top: 0; } 
    h1 { font-size: clamp(2.25rem, 5vw, 4.6rem); line-height: 1.02; margin: 14px 0 18px; letter-spacing: -.055em; } 
    h2 { font-size: clamp(1.75rem, 3vw, 2.65rem); letter-spacing: -.04em; line-height: 1.1; } 
    h3 { font-size: 1.1rem; margin-bottom: 8px; }
    .hero p { max-width: 600px; color: rgba(255,255,255,.9); font-size: 1.08rem; }
    
    .cta-row, .action-row { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 24px; }
    .btn { 
      display: inline-flex; align-items: center; justify-content: center; gap: 8px; border: 0; 
      border-radius: 12px; padding: 12px 24px; color: var(--ink); background: #fff; cursor: pointer; 
      font-weight: 750; text-decoration: none; transition: transform .18s ease, box-shadow .18s ease; 
    }
    .btn:hover { transform: translateY(-2px); box-shadow: 0 10px 22px rgba(20,32,60,.16); }
    .btn.primary { color: #fff; background: linear-gradient(135deg, #ff3700, #ff8c00); } 
    .btn.ghost { border: 1px solid var(--line); background: #fff; }
    .hero .btn.primary { color: var(--ink); background: #fff; }

    /* Cards */
    .section { margin-top: 56px; }
    .section-heading { display: flex; justify-content: space-between; align-items: end; gap: 20px; margin-bottom: 20px; }
    .section-heading p { max-width: 580px; margin: 0; color: var(--muted); }
    .grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 24px; }
    
    .company-card { 
      display: flex; flex-direction: column; overflow: hidden; border: 1px solid var(--line); 
      border-radius: 22px; color: var(--ink); background: #fff; box-shadow: 0 7px 21px rgba(23,40,79,.05); 
      cursor: pointer; text-align: left; transition: transform .2s ease, box-shadow .2s ease; 
    }
    .company-card:hover { transform: translateY(-5px); box-shadow: var(--shadow); }
    .company-image { width: 100%; height: 160px; object-fit: cover; background: #e6eaf2; }
    .company-content { padding: 22px; flex: 1; }
    .company-icon { 
      display: inline-grid; place-items: center; width: 42px; height: 42px; margin-bottom: 16px; 
      border-radius: 14px; color: #fff; font-size: 1.3rem; 
    }
    .company-card p { color: var(--muted); font-size: .93rem; margin-bottom: 0; }
    
    .nexora .company-icon { background: linear-gradient(135deg, #315efb, #17a2ff); }
    .axion .company-icon { background: linear-gradient(135deg, #ff7a18, #f14668); }
    .envolva .company-icon { background: linear-gradient(135deg, #e84d9b, #ff8e4f); }
    .orbita .company-icon { background: linear-gradient(135deg, #8b4df5, #315efb); }
    .sentinela .company-icon { background: linear-gradient(135deg, #12a879, #16b7ba); }
    .supria .company-icon { background: linear-gradient(135deg, #f2b705, #ff7a18); }

    /* Company Inner Page */
    .company-hero { 
      position: relative; overflow: hidden; padding: 60px 42px; border-radius: 28px; color: #fff; 
      background: linear-gradient(135deg, #e84d9b, #ff7a18); box-shadow: var(--shadow); 
    }
    .company-hero-bg {
      position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0.3; mix-blend-mode: overlay; z-index: 0;
    }
    .company-hero-content { position: relative; z-index: 1; }
    .company-hero .eyebrow { background: rgba(255,255,255,.22); }
    .company-hero p { max-width: 650px; color: rgba(255,255,255,.9); font-size: 1.1rem; }
    
    .company-hero.variant-nexora { background: linear-gradient(135deg, #315efb, #17a2ff); }
    .company-hero.variant-axion { background: linear-gradient(135deg, #ff7a18, #f14668); }
    .company-hero.variant-orbita { background: linear-gradient(135deg, #8b4df5, #315efb); }
    .company-hero.variant-sentinela { background: linear-gradient(135deg, #12a879, #16b7ba); }
    .company-hero.variant-supria { background: linear-gradient(135deg, #e7a800, #ff7a18); }

    /* Layout & Forms */
    .split { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-top: 24px; }
    .panel { padding: 32px; border: 1px solid var(--line); border-radius: 22px; background: #fff; box-shadow: 0 7px 21px rgba(23,40,79,.04); }
    .checklist { margin: 0; padding-left: 20px; color: var(--muted); }
    .checklist li { margin: 12px 0; }
    
    .contact-form { display: grid; gap: 16px; }
    label { display: grid; gap: 8px; font-weight: 600; color: var(--ink); }
    input, select, textarea { 
      width: 100%; padding: 14px; border: 1px solid #dbe1ee; border-radius: 12px; 
      color: var(--ink); background: #f9fbfd; outline-color: var(--orange); transition: border .2s;
    }
    input:focus, select:focus, textarea:focus { border-color: var(--orange); background: #fff; }
    textarea { min-height: 120px; resize: vertical; }
    .form-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .form-layout .full { grid-column: 1 / -1; }

    /* Client Storage Table */
    .requests { margin-top: 32px; overflow: hidden; border: 1px solid var(--line); border-radius: 17px; background: #fff; box-shadow: 0 4px 12px rgba(0,0,0,.03); }
    .requests-header { padding: 20px; border-bottom: 1px solid var(--line); background: #fdfdfe; display: flex; justify-content: space-between; align-items: center;}
    .requests table { width: 100%; border-collapse: collapse; text-align: left; }
    .requests th, .requests td { padding: 16px 20px; border-bottom: 1px solid var(--line); font-size: .95rem; }
    .requests th { color: var(--muted); font-weight: 700; background: #f9fbfd; }
    .requests tr:last-child td { border: 0; }
    .status { display: inline-block; padding: 6px 12px; border-radius: 999px; color: #b14800; background: #ffe4cc; font-size: .8rem; font-weight: 700; }

    footer { padding: 42px 0; color: #6c7894; font-size: .9rem; text-align: center; border-top: 1px solid var(--line); margin-top: 60px; }
    
    @media (max-width: 820px) { 
      .hero-grid, .split { grid-template-columns: 1fr; } 
      .grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } 
      .form-layout { grid-template-columns: 1fr; } 
    }
    @media (max-width: 600px) { 
      .grid { grid-template-columns: 1fr; } 
      .hero { padding: 32px 24px; }
    }
  </style>
</head>
<body>
  <header class="topbar">
    <nav class="shell nav">
      <a class="brand" href="#inicio" data-route="inicio">
        <img src="https://www.image2url.com/r2/default/images/1784714981959-d02e5733-58a3-4668-9ed3-c55ec3a9f53f.png" alt="Logo Grupo Vertex" class="brand-logo">
        GRUPO VERTEX
      </a>
      <div class="nav-links">
        <button type="button" data-route="inicio" class="active">Início</button>
        <button type="button" data-route="empresas">Empresas</button>
        <button type="button" data-route="central">Central / CRM</button>
      </div>
    </nav>
  </header>

  <main class="shell">
    <!-- INÍCIO -->
    <section class="view active" id="inicio">
      <div class="hero">
        <div class="hero-grid">
          <div>
            <span class="eyebrow">Ecossistema Empresarial</span>
            <h1>Ideias conectadas.<br>Soluções que avançam.</h1>
            <p>O Grupo Vertex reúne empresas especializadas para resolver desafios industriais, de tecnologia, embalagem, comércio, segurança e compras com precisão e eficiência.</p>
            <div class="cta-row">
              <button class="btn primary" type="button" data-route="empresas">Conheça as empresas</button>
              <button class="btn" type="button" data-route="central">Acessar Central</button>
            </div>
          </div>
        </div>
      </div>
      <section class="section">
        <div class="section-heading">
          <div>
            <span class="eyebrow" style="color:#ff5e00;background:#ffe6d4">Nossas empresas</span>
            <h2>Autonomia na execução.<br>Integração no resultado.</h2>
          </div>
        </div>
        <div class="grid" id="home-company-grid"></div>
      </section>
    </section>

    <!-- EMPRESAS -->
    <section class="view" id="empresas">
      <div class="section-heading">
        <div>
          <span class="eyebrow" style="color:#ff5e00;background:#ffe6d4">Portfólio Industrial e Tech</span>
          <h2>Especialistas na linguagem do seu desafio.</h2>
        </div>
      </div>
      <div class="grid" id="company-grid"></div>
    </section>

    <!-- PÁGINA DA EMPRESA (Dinâmica) -->
    <section class="view" id="empresa">
      <div id="company-page"></div>
    </section>

    <!-- CENTRAL / CRM -->
    <section class="view" id="central">
      <div class="section-heading">
        <div>
          <span class="eyebrow" style="color:#ff5e00;background:#ffe6d4">Central Grupo Vertex</span>
          <h2>Gestão de Solicitações e Contatos</h2>
        </div>
        <p>Preencha os dados abaixo. O e-mail será enviado automaticamente para a administração e o registro ficará salvo no painel abaixo.</p>
      </div>
      
      <div class="split">
        <!-- FORMULÁRIO CONFIGURADO COM WEB3FORMS -->
        <form class="panel contact-form" id="request-form" action="https://api.web3forms.com/submit" method="POST">
          <h3>Nova solicitação</h3>
          
          <!-- Chave do Web3Forms -->
          <input type="hidden" name="access_key" value="24b279d4-5c95-4f20-b149-cc1cf4263657">
          <input type="hidden" name="subject" value="Nova Solicitação - Grupo Vertex">
          <input type="hidden" name="from_name" value="Central Grupo Vertex">

          <div class="form-layout">
            <label>Cliente / Empresa
              <input id="requester" name="Cliente" required placeholder="Ex.: Auto Peças Horizonte">
            </label>
            <label>E-mail para retorno
              <input id="reply-email" name="Email" type="email" required placeholder="voce@empresa.com">
            </label>
            <label>Empresa requerida
              <select id="request-company" name="Empresa_Destino" required></select>
            </label>
            <label>Tipo de demanda
              <select id="request-type" name="Tipo">
                <option>Orçamento</option>
                <option>Projeto integrado</option>
                <option>Suporte / Manutenção</option>
                <option>Parceria</option>
              </select>
            </label>
            <label class="full">Assunto
              <input id="request-subject" name="Assunto" required placeholder="Ex.: Peças usinadas em alumínio">
            </label>
            <label class="full">Detalhes Técnicos
              <textarea id="request-message" name="Mensagem" required placeholder="Especifique materiais, quantidades, escopo tecnológico, etc."></textarea>
            </label>
          </div>
          <div class="action-row">
            <button class="btn primary" type="submit">Enviar e Salvar Registro</button>
          </div>
          <span id="request-feedback" style="color: var(--orange); font-weight: 600; margin-top: 10px; display: block;"></span>
        </form>

        <div class="panel">
          <h3>Como funciona o painel?</h3>
          <ul class="checklist">
            <li><strong>Envio Real:</strong> Ao clicar em enviar, os dados vão direto para o e-mail central.</li>
            <li><strong>Armazenamento Local:</strong> Os dados do cliente também são salvos no navegador (Local Storage), formando o painel de histórico abaixo.</li>
            <li><strong>Organização:</strong> Todas as demandas são tagueadas por área para facilitar a triagem.</li>
          </ul>
        </div>
      </div>

      <!-- Tabela de Registros Salvos -->
      <div class="requests">
        <div class="requests-header">
          <h3 style="margin:0;">Histórico de Clientes (Local)</h3>
          <button class="btn ghost" type="button" onclick="clearRequests()" style="padding: 6px 12px; font-size: 0.85rem;">Limpar Histórico</button>
        </div>
        <table>
          <thead>
            <tr>
              <th>Protocolo</th>
              <th>Cliente</th>
              <th>Empresa</th>
              <th>Assunto</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody id="request-list"></tbody>
        </table>
      </div>
    </section>
  </main>

  <footer>
    <div class="shell">© <span id="year"></span> Grupo Vertex · Soluções Conectadas para a Indústria e o Mercado.</div>
  </footer>

  <script>
    const companies = {
      nexora: { name: 'Nexora Tech', area: 'Tecnologia', className: 'nexora', icon: '◈', tag: 'Sistemas e ERP', description: 'Desenvolvimento de sistemas e arquiteturas para operações conectadas e rastreabilidade.', services: ['Desenvolvimento Web', 'Integração de Sistemas', 'Automação e Sensores'], color: 'variant-nexora', img: 'https://images.unsplash.com/photo-1518770660439-4636190af475?auto=format&fit=crop&w=600&q=80' },
      axion: { name: 'Axion Industrial', area: 'Usinagem', className: 'axion', icon: '⚙', tag: 'Mecânica de Precisão', description: 'Usinagem e projetos mecânicos para transformar necessidades industriais em realidade.', services: ['Usinagem em CNC', 'Manutenção Industrial', 'Prototipagem 3D'], color: 'variant-axion', img: 'https://images.unsplash.com/photo-1565514020179-026b92b84bb6?auto=format&fit=crop&w=600&q=80' },
      envolva: { name: 'Envolva Embalagens', area: 'Embalagem', className: 'envolva', icon: '▣', tag: 'Logística Segura', description: 'Soluções em embalagens master e proteção estrutural para a cadeia de suprimentos.', services: ['Projetos de Embalagem', 'Estudos de Fragilidade', 'Padronização Logística'], color: '', img: 'https://images.unsplash.com/photo-1605600659908-0ef719419d41?auto=format&fit=crop&w=600&q=80' },
      orbita: { name: 'Órbita Comércio', area: 'Comércio', className: 'orbita', icon: '↗', tag: 'Mercados Ativos', description: 'Canais de e-commerce e distribuição B2B/B2C.', services: ['Gestão de Vendas', 'Distribuição de Produtos', 'Atendimento ao Cliente'], color: 'variant-orbita', img: 'https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?auto=format&fit=crop&w=600&q=80' },
      sentinela: { name: 'Sentinela Segurança', area: 'Segurança', className: 'sentinela', icon: '◉', tag: 'Auditoria e Monitoramento', description: 'Monitoramento corporativo e segurança para ambientes de alto risco.', services: ['Controle de Acesso', 'Segurança Patrimonial', 'CFTV e Monitoramento'], color: 'variant-sentinela', img: 'https://images.unsplash.com/photo-1557597774-9d273605dfa9?auto=format&fit=crop&w=600&q=80' },
      supria: { name: 'Supria Compras', area: 'Compras', className: 'supria', icon: '◆', tag: 'Sourcing Estratégico', description: 'Organização da cadeia de suprimentos e suprimentos essenciais.', services: ['Gestão de Fornecedores', 'Cotações Globais', 'Redução de Custos'], color: 'variant-supria', img: 'https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?auto=format&fit=crop&w=600&q=80' }
    };

    const views = [...document.querySelectorAll('.view')];
    const navButtons = [...document.querySelectorAll('[data-route]')];
    let protocolNumber = Number(localStorage.getItem('gf-protocol-number') || 100);

    const renderCards = (target) => { 
      document.getElementById(target).innerHTML = Object.entries(companies).map(([key, c]) => `
        <div class="company-card ${c.className}" data-company="${key}">
          <img src="${c.img}" alt="${c.name}" class="company-image">
          <div class="company-content">
            <span class="company-icon">${c.icon}</span>
            <h3>${c.name}</h3>
            <p>${c.area} · ${c.tag}</p>
          </div>
        </div>
      `).join(''); 
    };

    const route = (name, company) => { 
      views.forEach(v => v.classList.toggle('active', v.id === name)); 
      navButtons.forEach(b => b.classList.toggle('active', b.dataset.route === name)); 
      if(name === 'empresa') renderCompany(company); 
      window.scrollTo({top: 0, behavior: 'smooth'}); 
    };

    const renderCompany = (key) => { 
      const c = companies[key]; 
      document.getElementById('company-page').innerHTML = `
        <div class="company-hero ${c.color}">
          <img src="${c.img}" class="company-hero-bg" alt="Fundo">
          <div class="company-hero-content">
            <span class="eyebrow">${c.area}</span>
            <h1>${c.name}</h1>
            <p>${c.description}</p>
          </div>
        </div>
        <section class="section split">
          <article class="panel">
            <h2>Especialidades</h2>
            <ul class="checklist">${c.services.map(s => `<li>${s}</li>`).join('')}</ul>
          </article>
          <article class="panel">
            <h2>Integração ao Grupo</h2>
            <p>A ${c.name} atua de forma conectada ao Grupo Vertex. Se o seu projeto demanda múltiplas áreas, nossa Central coordena a execução.</p>
            <button class="btn primary" type="button" data-central-company="${c.name}">Solicitar Projeto à ${c.name}</button>
          </article>
        </section>
      `; 
    };

    document.addEventListener('click', (event) => { 
      const card = event.target.closest('.company-card');
      if (card) route('empresa', card.dataset.company); 
      
      const routeButton = event.target.closest('[data-route]'); 
      if (routeButton) { event.preventDefault(); route(routeButton.dataset.route); } 
      
      const centralButton = event.target.closest('[data-central-company]'); 
      if (centralButton) { 
        document.getElementById('request-company').value = centralButton.dataset.centralCompany; 
        route('central'); 
      } 
    });

    const getRequests = () => JSON.parse(localStorage.getItem('gf-requests') || '[]');
    
    const renderRequests = () => { 
      const rows = getRequests(); 
      document.getElementById('request-list').innerHTML = rows.length 
        ? rows.map(r => `<tr>
            <td><strong>${r.protocol}</strong></td>
            <td>${r.requester}<br><small style="color:var(--muted)">${r.reply}</small></td>
            <td>${r.company}</td>
            <td>${r.subject}</td>
            <td><span class="status">Registrado</span></td>
          </tr>`).join('') 
        : '<tr><td colspan="5" style="text-align:center; padding: 40px; color: var(--muted);">Nenhum cliente registrado ainda.</td></tr>'; 
    };

    const clearRequests = () => {
      if(confirm("Deseja realmente limpar o histórico de clientes salvos neste navegador?")) {
        localStorage.removeItem('gf-requests');
        renderRequests();
      }
    };

    document.getElementById('request-form').addEventListener('submit', function(event) {
      event.preventDefault(); 
      
      const feedbackElement = document.getElementById('request-feedback');
      feedbackElement.style.color = 'var(--orange)';
      feedbackElement.textContent = "Enviando solicitação...";
      
      const localData = {
        protocol: `GF-${String(protocolNumber++).padStart(4, '0')}`,
        requester: document.getElementById('requester').value.trim(),
        reply: document.getElementById('reply-email').value.trim(),
        company: document.getElementById('request-company').value,
        subject: document.getElementById('request-subject').value.trim()
      }; 
      
      localStorage.setItem('gf-protocol-number', protocolNumber); 
      const requests = getRequests(); 
      requests.unshift(localData); 
      localStorage.setItem('gf-requests', JSON.stringify(requests)); 
      renderRequests();

      const formData = new FormData(this);

      fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        body: formData
      })
      .then(response => response.json())
      .then(data => {
        if (data.success) {
          feedbackElement.style.color = 'var(--green)';
          feedbackElement.textContent = "Sucesso! Solicitação enviada e registrada no painel.";
          this.reset();
        } else {
          feedbackElement.style.color = 'red';
          feedbackElement.textContent = "Erro da API: " + data.message;
        }
      })
      .catch(error => {
        feedbackElement.style.color = 'red';
        feedbackElement.textContent = "Erro ao enviar. Verifique sua conexão.";
      });
    });

    document.getElementById('request-company').innerHTML = Object.values(companies).map(c => `<option value="${c.name}">${c.name}</option>`).join('');
    renderCards('home-company-grid'); 
    renderCards('company-grid'); 
    renderRequests(); 
    document.getElementById('year').textContent = new Date().getFullYear();
  </script>
</body>
</html>


