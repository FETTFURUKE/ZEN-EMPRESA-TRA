  <script>
    const views = [...document.querySelectorAll('.view')];
    const navButtons = [...document.querySelectorAll('[data-route]')];
    let protocolNumber = Number(localStorage.getItem('gf-protocol-number') || 100);

    const route = (name) => { 
      const isLoggedIn = sessionStorage.getItem('isAdminLogged') === 'true';

      if (name === 'admin' && !isLoggedIn) {
        name = 'admin-login';
      }

      views.forEach(v => v.classList.toggle('active', v.id === name)); 
      
      navButtons.forEach(b => {
        if (name === 'admin-login' && b.dataset.route === 'admin') {
           b.classList.add('active');
        } else {
           b.classList.toggle('active', b.dataset.route === name); 
        }
      });
      
      if(name === 'admin') renderAdminTable(); 
      window.scrollTo({top: 0, behavior: 'smooth'}); 
    };

    document.addEventListener('click', (event) => { 
      const routeButton = event.target.closest('[data-route]'); 
      if (routeButton) { event.preventDefault(); route(routeButton.dataset.route); } 
    });

    document.getElementById('login-form').addEventListener('submit', function(e) {
      e.preventDefault();
      const user = document.getElementById('login-user').value.trim();
      const pass = document.getElementById('login-pass').value.trim();

      if (user === 'admin' && pass === 'aprendizagem2026') {
        sessionStorage.setItem('isAdminLogged', 'true');
        document.getElementById('login-feedback').textContent = '';
        this.reset();
        route('admin');
      } else {
        document.getElementById('login-feedback').textContent = 'Usuário ou senha incorretos.';
      }
    });

    window.logoutAdmin = () => {
      sessionStorage.removeItem('isAdminLogged');
      route('inicio');
    };

    const getRequests = () => JSON.parse(localStorage.getItem('gf-requests') || '[]');
    
    const renderAdminTable = () => {
      const rows = getRequests(); 
      document.getElementById('admin-request-list').innerHTML = rows.length 
        ? rows.map(r => {
            const isAnswered = r.status === 'Respondido';
            return `<tr>
              <td><strong>${r.protocol}</strong> - ${r.requester} <br><small style="color:var(--muted)">✉️ ${r.email || 'Não informado'}</small></td>
              <td><span class="status ${isAnswered ? 'answered' : 'pending'}">${isAnswered ? 'A3 Enviado' : 'Pendente'}</span></td>
              <td><button class="btn ghost small" onclick="loadAdminForm('${r.protocol}')">${isAnswered ? 'Editar A3' : 'Preencher A3'}</button></td>
            </tr>`;
          }).join('') 
        : '<tr><td colspan="3" style="text-align:center; padding: 20px;">Nenhum chamado registrado.</td></tr>'; 
    };

    document.getElementById('request-form').addEventListener('submit', function(event) {
      event.preventDefault(); 
      const localData = {
        protocol: `GF-${String(protocolNumber++).padStart(4, '0')}`,
        requester: document.getElementById('requester').value.trim(),
        email: document.getElementById('reply-email').value.trim(),
        company: document.getElementById('request-company').value,
        subject: document.getElementById('request-subject').value.trim(),
        message: document.getElementById('request-message').value.trim(),
        status: 'Registrado',
        adminReply: null 
      }; 
      localStorage.setItem('gf-protocol-number', protocolNumber); 
      const requests = getRequests(); 
      requests.unshift(localData); 
      localStorage.setItem('gf-requests', JSON.stringify(requests)); 
      
      document.getElementById('request-feedback').textContent = `Protocolo ${localData.protocol} gerado com sucesso!`;
      this.reset();
    });

    window.loadAdminForm = (protocol) => {
      const requests = getRequests();
      const req = requests.find(r => r.protocol === protocol);
      if(!req) return;

      const panel = document.getElementById('admin-reply-panel');
      panel.style.opacity = '1'; panel.style.pointerEvents = 'all';
      
      document.getElementById('admin-protocol').value = req.protocol;
      document.getElementById('admin-feedback').textContent = "";
      document.getElementById('a3-data').value = new Date().toISOString().split('T')[0];

      if(req.adminReply) {
        document.getElementById('a3-equipe').value = req.adminReply.equipe || '';
        document.getElementById('a3-responsavel').value = req.adminReply.resp || '';
        document.getElementById('a3-background').value = req.adminReply.bg || '';
        document.getElementById('a3-analise').value = req.adminReply.analise || '';
        document.getElementById('a3-meta').value = req.adminReply.meta || '';
        document.getElementById('a3-recomendacoes').value = req.adminReply.rec || '';
        document.getElementById('a3-plano').value = req.adminReply.plano || '';
        document.getElementById('a3-resultados').value = req.adminReply.resultados || '';
      } else {
        document.getElementById('admin-reply-form').reset();
        document.getElementById('a3-data').value = new Date().toISOString().split('T')[0];
      }
      
      window.scrollTo({top: document.getElementById('admin-reply-panel').offsetTop - 100, behavior: 'smooth'});
    };

    // Envio do Relatório A3 utilizando a API do EmailJS integrada
    document.getElementById('admin-reply-form').addEventListener('submit', function(event) {
      event.preventDefault();
      
      const protocol = document.getElementById('admin-protocol').value;
      let requests = getRequests();
      let reqIndex = requests.findIndex(r => r.protocol === protocol);
      
      if(reqIndex > -1) {
        const clientEmail = requests[reqIndex].email;
        const clientName = requests[reqIndex].requester;
        const submitBtn = document.getElementById('submit-btn');

        const templateParams = {
          to_email: clientEmail,
          client_name: clientName,
          protocol: protocol,
          equipe: document.getElementById('a3-equipe').value,
