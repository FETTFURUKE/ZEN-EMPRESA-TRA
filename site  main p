              <button class="btn ghost" style="color:#fff; border-color:rgba(255,255,255,0.3); background:transparent" type="button" data-route="empresas">Conhecer o Grupo</button>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="view" id="empresas">
      <div class="section-heading">
        <div>
          <h2>Nossas Empresas</h2>
        </div>
        <p>Um conjunto completo para atender demandas desde o inicio ao fim</p>
      </div>
      <div class="grid">
        <div class="company-card nexora">
          <div class="company-content">
            <div class="company-icon">⚙️</div>
            <h3>Nexora Tech</h3>
            <p>1° em soluçoes de tecnologia e sistemas</p>
          </div>
        </div>
        <div class="company-card axion">
          <div class="company-content">
            <div class="company-icon">🔧</div>
            <h3>Axion Industrial</h3>
            <p>Foco em mecânica de precisão e suporte para maquinário pesado industrial.</p>
          </div>
        </div>
        <div class="company-card envolva">
          <div class="company-content">
            <div class="company-icon">📦</div>
            <h3>Envolva Log</h3>
            <p>Logística inteligente e armazenamento seguro para garantir as entregas no prazo ideal.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="view" id="central">
      <div class="section-heading">
        <div>
