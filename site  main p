              <div class="a3-section" style="margin-top: 16px;">
                <h3 class="a3-section-title">3) Meta / Objetivo</h3>
                <textarea id="a3-meta" placeholder="Indicadores e metas a serem alcançadas..." style="min-height: 80px;"></textarea>
                <input type="file" id="pdf-meta" accept=".pdf">
              </div>
            </div>

            <div class="a3-col">
              <div class="a3-section">
                <h3 class="a3-section-title">4) Recomendações / Situação alvo</h3>
