            <div>
              <label>Data Atual</label>
              <input type="date" id="a3-data">
            </div>
          </div>

          <div class="a3-grid">
            <div class="a3-col">
              <div class="a3-section">
                <h3 class="a3-section-title">1) Background - Cenário</h3>
                <textarea id="a3-background" placeholder="Contexto geral do problema..."></textarea>
                <input type="file" id="pdf-background" accept=".pdf">
